            public class AEDataByIdQueueable implements Queueable, Database.AllowsCallouts {
    private List<Id> allPaeIds;
    private Integer batchNumber;
    private Map<Id, Integer> retryAttempts;
    private static final Integer MAX_RETRIES = 3;

    // Original constructor — unchanged, still works exactly as before
    public AEDataByIdQueueable(List<Id> allPaeIds, Integer batchNumber) {
        this.allPaeIds = allPaeIds;
        this.batchNumber = batchNumber;
        this.retryAttempts = new Map<Id, Integer>();
    }

    // NEW constructor — used internally for retries, carries forward attempt counts
    public AEDataByIdQueueable(List<Id> allPaeIds, Integer batchNumber, Map<Id, Integer> retryAttempts) {
        this.allPaeIds = allPaeIds;
        this.batchNumber = batchNumber;
        this.retryAttempts = retryAttempts;
    }

    public void execute(QueueableContext context) {
        Integer startIndex = batchNumber * BATCH_SIZE;
        Integer endIndex = Math.min(startIndex + BATCH_SIZE, allPaeIds.size());

        if (startIndex >= allPaeIds.size()) {
            System.debug('No more AE records to process.');
            return;
        }

        List<Id> currentBatch = new List<Id>();
        for (Integer i = startIndex; i < endIndex; i++) {
            currentBatch.add(allPaeIds[i]);
        }

        System.debug('Processing AE batch ' + (batchNumber + 1));
        System.debug('Current AE batch size: ' + currentBatch.size());
        System.debug('Current AE IDs: ' + currentBatch);

        String token = getOAuthToken();

        if (token == null) {
            System.debug('Failed to get OAuth token for AE batch.');
            createOptOutLog(
                'Authentication Failed - AE Batch ' + batchNumber,
                AUTH_URL,
                'Failed to obtain OAuth token',
                null,
                0,
                'Failure'
            );
            return;
        }

        List<New_Potential_Adverse_Event__c> paes = [
            SELECT Id
            FROM New_Potential_Adverse_Event__c
            WHERE Id IN :currentBatch
        ];

        System.debug('AE records found for callout: ' + paes.size());

        // NEW: track which records fail in this run
        List<Id> failedIds = new List<Id>();

        for (New_Potential_Adverse_Event__c pae : paes) {
            Boolean success = sendSingleAEDataSafely(pae.Id, token);
            if (!success) {
                failedIds.add(pae.Id);
            }
        }

        // NEW: handle retries for anything that failed in this batch
        if (!failedIds.isEmpty()) {
            Map<Id, Integer> updatedAttempts = retryAttempts.clone();
            List<Id> stillRetryable = new List<Id>();

            for (Id failedId : failedIds) {
                Integer attempts = updatedAttempts.containsKey(failedId) ? updatedAttempts.get(failedId) : 0;
                attempts++;
                updatedAttempts.put(failedId, attempts);

                if (attempts < MAX_RETRIES) {
                    stillRetryable.add(failedId);
                } else {
                    System.debug('Max retries reached for: ' + failedId);
                    createOptOutLog(
                        'Max Retries Exceeded - ' + failedId,
                        BhoomiVeeva_URL,
                        '',
                        '',
                        0,
                        'Failure - Exhausted Retries'
                    );
                }
            }

            if (!stillRetryable.isEmpty() && !Test.isRunningTest()) {
                System.enqueueJob(new AEDataByIdQueueable(stillRetryable, 0, updatedAttempts));
            }
        }

        // Original chaining logic — unchanged
        if (endIndex < allPaeIds.size()) {
            System.enqueueJob(new AEDataByIdQueueable(allPaeIds, batchNumber + 1, retryAttempts));
        } else {
            System.debug('Completed all AE records sent to Boomi. Total: ' + allPaeIds.size());
        }
    }
}

