
private static Case createTestCase() {
    // Query existing product instead of inserting new one
    MICC_Product__c prod = [
        SELECT Id, Name 
        FROM MICC_Product__c 
        LIMIT 1
    ];
    
    Case c = new Case(
        Subject = 'Test Case',
        Status = 'New',
        Origin = 'Phone',
        MICC_Notes_History__c = 'Escalation test notes',
        MICC_CaseNumber__c = 'CASE12345',
        MICC_Source__c = 'EMAIL',
        MICC_Received_Date__c = Date.today(),
        MICC_Inquiry_For__c = 'Self',
        MICC_Customer_Type__c = 'Consumer',
        MICC_First_Name__c = 'John',
        MICC_Last_Name__c = 'Doe',
        MICC_Salutation__c = 'Mr.',
        MICC_Org_name__c = 'ABC Org',
        MICC_Address_Line_1__c = '123 Test',
        MICC_Address_Line_2__c = 'Apt 4',
        MICC_City__c = 'Dallas',
        MICC_State__c = 'TX',
        MICC_Zip_Code__c = '75001',
        MICC_Phone__c = '1234567890',
        MICC_Email__c = 'john.doe@test.com',
        MICC_Fax__c = '1112223333',
        MICC_Product__c = prod.Id
    );
    insert c;
    return c;
}
// FROM:
