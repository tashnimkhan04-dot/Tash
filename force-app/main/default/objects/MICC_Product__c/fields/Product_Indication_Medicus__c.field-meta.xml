public List<SelectOption> getRouteOptions() {
    List<SelectOption> options = new List<SelectOption>();
    options.add(new SelectOption('', '--None--'));
    for (Schema.PicklistEntry e : New_Potential_Adverse_Event__c.Route_of_Administering__c.getDescribe().getPicklistValues()) {
        options.add(new SelectOption(e.getValue(), e.getLabel()));
    }
    return options;
}

