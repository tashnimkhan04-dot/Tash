function confirmSaveCase() {
    var lastNameInput = document.querySelector("input[id*='Reporter_Last_Name']");
    var productTable = document.querySelector('.productTable tbody');
    var firstRow = productTable ? productTable.querySelector('tr:first-child') : null;
    var productInput = firstRow ? firstRow.querySelectorAll('td')[1].querySelector('input') : null;
    var eventDescInput = document.querySelector('.fullWidthTextarea');

    var isLastNameEmpty = !lastNameInput || lastNameInput.value.trim() === '';
    var isProductEmpty = !productInput || productInput.value.trim() === '';
    var isEventDescEmpty = !eventDescInput || eventDescInput.value.trim() === '';

    // Combined message
    if (isLastNameEmpty && isProductEmpty && isEventDescEmpty) {
        alert('Please fill the required fields: Reporter Last Name, Product Name and Event Description.');
        return false;
    }
    if (isLastNameEmpty && isProductEmpty) {
        alert('Please fill the required fields: Reporter Last Name and Product Name.');
        return false;
    }
    if (isLastNameEmpty && isEventDescEmpty) {
        alert('Please fill the required fields: Reporter Last Name and Event Description.');
        return false;
    }
    if (isProductEmpty && isEventDescEmpty) {
        alert('Please fill the required fields: Product Name and Event Description.');
        return false;
    }

    // Individual with native tooltip
    if (isLastNameEmpty) {
        lastNameInput.setCustomValidity('Please enter the Reporter Last Name.');
        lastNameInput.reportValidity();
        return false;
    }
    lastNameInput.setCustomValidity('');

    if (isProductEmpty) {
        productInput.setCustomValidity('Please enter the Product name.');
        productInput.reportValidity();
        return false;
    }
    productInput.setCustomValidity('');

    if (isEventDescEmpty) {
        eventDescInput.setCustomValidity('Please enter the Event Description.');
        eventDescInput.reportValidity();
        return false;
    }
    eventDescInput.setCustomValidity('');

    return true;
}
