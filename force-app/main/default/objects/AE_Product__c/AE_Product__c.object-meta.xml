    @isTest
    static void testWithProductData() {
        New_Potential_Adverse_Event__c pae = [
            SELECT Id FROM New_Potential_Adverse_Event__c LIMIT 1
        ];

        Test.startTest();
        ApexPages.StandardController sc = new ApexPages.StandardController(pae);
        PAE_ProductInfoController ctrl = new PAE_ProductInfoController(sc);
        Test.stopTest();

        // Verify rows populated
        System.assertNotEquals(null, ctrl.productRows);
        System.assertEquals(2, ctrl.productRows.size());

        // Verify first row values
        PAE_ProductInfoController.ProductRow row1 = ctrl.productRows[0];
        System.assertEquals('1', row1.srNo);
        System.assertEquals('Adakveo', row1.productName);
        System.assertEquals('Suspect', row1.productType);
        System.assertEquals('Test Indication', row1.indication);
        System.assertEquals('10.5', row1.dose);
        System.assertEquals('mg', row1.doseUnit);
        System.assertEquals('2', row1.frequency);
        System.assertEquals('Oral', row1.route);
        System.assertEquals('LOT001', row1.lotNumber);
        System.assertEquals('2026-12-31', row1.expiryDate);
        System.assertEquals('2026-01-01', row1.therapyStartDate);
        System.assertEquals('2026-06-30', row1.therapyEndDate);
        System.assertEquals('Yes', row1.pickupStatus);
        System.assertEquals('No', row1.technicalComplaint);
        System.assertEquals('TC001', row1.technicalComplaintNumber);
        System.assertEquals('Test description', row1.technicalComplaintDescription);

        // Verify second row
        PAE_ProductInfoController.ProductRow row2 = ctrl.productRows[1];
        System.assertEquals('2', row2.srNo);
        System.assertEquals('Test Product', row2.productName);
    }

