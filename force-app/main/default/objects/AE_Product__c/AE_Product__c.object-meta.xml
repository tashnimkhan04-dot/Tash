<aura:component implements="lightning:actionOverride,lightning:isUrlAddressable"
                access="global">

    <lightning:workspaceAPI aura:id="workspace"/>
    <aura:attribute name="pageReference" type="Object"/>
    <aura:attribute name="vfUrl" type="String"/>

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <iframe src="{!v.vfUrl}"
            style="width:100%; height:100vh; border:0;"
            frameborder="0"/>
</aura:component>
2. Replace Aura JS Controller

({
    doInit : function(component, event, helper) {
        var pageRef = component.get("v.pageReference");
        var caseId;

        if (pageRef && pageRef.state && pageRef.state.inContextOfRef) {
            var context = pageRef.state.inContextOfRef;

            if (context.startsWith("1.")) {
                context = context.substring(2);
            }

            context = context.replace(/-/g, "+").replace(/_/g, "/");

            var decodedContext = JSON.parse(window.atob(context));
            caseId = decodedContext.attributes.recordId;
        }

        var vfUrl = "/apex/CCMIC_AE_CreateForm";

        if (caseId) {
            vfUrl += "?caseId=" + encodeURIComponent(caseId);
        }

        component.set("v.vfUrl", vfUrl);

        window.addEventListener("message", $A.getCallback(function(event) {
            if (!event.data || event.data.type !== "AE_SET_TAB_TITLE") {
                return;
            }

            var sourceId = event.data.sourceId;

            if (!sourceId) {
                return;
            }

            var workspaceAPI = component.find("workspace");

            workspaceAPI.isConsoleNavigation().then(function(isConsole) {
                if (isConsole) {
                    workspaceAPI.getFocusedTabInfo().then(function(tabInfo) {
                        workspaceAPI.setTabLabel({
                            tabId: tabInfo.tabId,
                            label: sourceId
                        });
                    });
                }
            });
        }), false);
    }
})
3. Add This In VF Page Script

Inside CCMIC_AE_CreateForm VF page, add this function:

function setLightningTabTitle() {
    try {
        var el = document.getElementById('hdnSourceId');
        if (!el) return;
        var sourceId = el.innerText.trim();
        if (!sourceId || sourceId === '') return;
        
        // Set document title — Lightning Console picks this up
        document.title = sourceId;
        
        // Post to parent for Aura listener if needed
        if (window.parent) {
            window.parent.postMessage({
                type: 'AE_SET_TAB_TITLE',
                sourceId: sourceId
            }, '*');
        }
    } catch(e) {
        console.log(e);
    }
}
Then call it inside your existing window.onload:

window.onload = function() {
    updateTime();
    setInterval(updateTime, 1000);

    setConsoleTabTitle();
    setTimeout(setConsoleTabTitle, 1000);
