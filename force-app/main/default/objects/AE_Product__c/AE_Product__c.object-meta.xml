var numericRegex = /^-?\d+(\.\d+)?$/;
var hasInvalid   = false;
var firstInvalid = null;

if (productTable) {
    productTable.querySelectorAll('tr').forEach(function(tr) {
        var tds = tr.querySelectorAll('td');
        if (tds.length < 7) return;

        var doseInput = tds[4].querySelector('input.numeric-field');
        var freqInput = tds[6].querySelector('input.numeric-field');

        [{inp: doseInput}, {inp: freqInput}].forEach(function(item) {
            var inp = item.inp;
            if (!inp) return;

            // Always reset first
            inp.classList.remove('is-invalid', 'is-valid');
            var errorEl = inp.parentNode.querySelector('.field-error');
            if (errorEl) errorEl.classList.remove('visible');

            var val = (inp.value || '').trim();

            // Empty = skip, no error
            if (val === '') return;

            if (!numericRegex.test(val)) {
                hasInvalid = true;
                inp.classList.add('is-invalid');
                if (errorEl) errorEl.classList.add('visible');
                if (!firstInvalid) firstInvalid = inp;
            } else {
                inp.classList.add('is-valid');
            }
        });
    });
}

if (hasInvalid) {
    if (firstInvalid) firstInvalid.focus();
    return false;
}

