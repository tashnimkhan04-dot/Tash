public PAE_ProductInfoController(ApexPages.StandardController sc) {
    productRows = new List<Map<String, Object>>();
    New_Potential_Adverse_Event__c pae = [
        SELECT Product_Info_JSON__c 
        FROM New_Potential_Adverse_Event__c 
        WHERE Id = :sc.getId()
    ];
    if (String.isNotBlank(pae.Product_Info_JSON__c)) {
        List<Object> parsed = (List<Object>) JSON.deserializeUntyped(pae.Product_Info_JSON__c);
        for (Object obj : parsed) {
            Map<String, Object> row = (Map<String, Object>) obj;
            // ensure all keys exist
            if (!row.containsKey('expiryDate')) row.put('expiryDate', null);
            if (!row.containsKey('therapyStartDate')) row.put('therapyStartDate', null);
            if (!row.containsKey('therapyEndDate')) row.put('therapyEndDate', null);
            if (!row.containsKey('indication')) row.put('indication', null);
            if (!row.containsKey('dose')) row.put('dose', null);
            if (!row.containsKey('frequency')) row.put('frequency', null);
            if (!row.containsKey('route')) row.put('route', null);
            if (!row.containsKey('lotNumber')) row.put('lotNumber', null);
            if (!row.containsKey('technicalComplaintNumber')) row.put('technicalComplaintNumber', null);
            if (!row.containsKey('technicalComplaintDescription')) row.put('technicalComplaintDescription', null);
            if (row.get('productName') != null || row.get('productType') != null) {
                productRows.add(row);
            }
        }
    }
}
                    
<apex:page standardController="New_Potential_Adverse_Event__c"
           extensions="PAE_ProductInfoController"
           readOnly="true"
           showHeader="false"
           sidebar="false">
<style>
    body { font-family: Arial, sans-serif; font-size: 11px; margin: 0; padding: 5px; }
    .prodTable { width:100%; border-collapse:collapse; }
    .prodTable th { background:#b7aca4; color:white; padding:5px 4px; text-align:center; font-size:10px; border:1px solid #d58f82; }
    .prodTable td { border:1px solid #ddd; padding:4px; text-align:center; font-size:10px; background:#fff; }
    .prodTable tr:nth-child(even) td { background:#f9f9f9; }
    .noData { color:#888; font-size:11px; padding:5px; }
</style>

<apex:outputPanel rendered="{!productRows.size > 0}">
    <table class="prodTable">
        <thead>
            <tr>
                <th>Sr No</th>
                <th>Product</th>
                <th>Product Type</th>
                <th>Indication</th>
                <th>Dose</th>
                <th>Frequency</th>
                <th>Route</th>
                <th>Lot No</th>
                <th>Expiry Date</th>
                <th>Therapy Start</th>
                <th>Therapy End</th>
                <th>Pickup Status</th>
                <th>Technical Complaint</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!productRows}" var="row">
                <tr>
                    <td>{!row['srNo']}</td>
                    <td>{!row['productName']}</td>
                    <td>{!row['productType']}</td>
                    <td>{!row['indication']}</td>
                    <td>{!row['dose']}</td>
                    <td>{!row['frequency']}</td>
                    <td>{!row['route']}</td>
                    <td>{!row['lotNumber']}</td>
                    <td>{!row['expiryDate']}</td>
                    <td>{!row['therapyStartDate']}</td>
                    <td>{!row['therapyEndDate']}</td>
                    <td>{!row['pickupStatus']}</td>
                    <td>{!row['technicalComplaint']}</td>
                </tr>
            </apex:repeat>
        </tbody>
    </table>
</apex:outputPanel>

<apex:outputPanel rendered="{!productRows.size == 0}">
    <p class="noData">No product information available.</p>
</apex:outputPanel>

</apex:page>

                    
