@isTest
public static void addNewPAEToMapTest() {
    Test.startTest();
    makeData();
    
    Case parent = [SELECT Id FROM Case WHERE Subject = 'parent' LIMIT 1];
    Case child = [SELECT Id FROM Case WHERE Subject = 'child' LIMIT 1];
    
    New_Potential_Adverse_Event__c npe1 = new New_Potential_Adverse_Event__c(
        Case_PAE__c = parent.Id,
        Child_Inquiry__c = child.Id,
        Source_System__c = 'CareConnect',
        Reporting_Date__c = Date.today(),
        Entity__c = 'Novartis'
    );
    insert npe1;
    
    New_Potential_Adverse_Event__c npe2 = new New_Potential_Adverse_Event__c(
        Case_PAE__c = parent.Id,
        Child_Inquiry__c = null,
        Source_System__c = 'CareConnect',
        Reporting_Date__c = Date.today(),
        Entity__c = 'Novartis'
    );
    insert npe2;
    
    // Same Child_Inquiry__c as npe1 - triggers alreadyExists = true (lines 130-132)
    New_Potential_Adverse_Event__c npe3 = new New_Potential_Adverse_Event__c(
        Case_PAE__c = parent.Id,
        Child_Inquiry__c = child.Id,
        Source_System__c = 'CareConnect',
        Reporting_Date__c = Date.today(),
        Entity__c = 'Novartis'
    );
    insert npe3;
    
    ApexPages.StandardController sc = new ApexPages.StandardController(parent);
    MICC_InquiryViewController micc = new MICC_InquiryViewController(sc);
    Test.setCurrentPage(Page.MICC_InquiryViewPage);
    micc.SelectedCounter = 0;
    
    micc.getBuildComponent();
    
    String url = micc.ConsoleIntegrationUrl;
    System.assertNotEquals(null, url);
    
    Test.stopTest();
}
