1. Aura Component

Open AE_CreateFormLauncher.cmp and use this:

<aura:component implements="lightning:actionOverride,lightning:isUrlAddressable"
                access="global">

    <lightning:workspaceAPI aura:id="workspace"/>

    <aura:attribute name="pageReference" type="Object"/>
    <aura:attribute name="vfUrl" type="String"/>

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <iframe src="{!v.vfUrl}"
            style="width:100%; height:100vh; border:0;"
            frameborder="0"/>
</aura:component>
2. Aura JS Controller

Open AE_CreateFormLauncherController.js and use:

({
    doInit : function(component, event, helper) {
        helper.registerTabTitleListener(component);

        var pageRef = component.get("v.pageReference");
        var state = pageRef && pageRef.state ? pageRef.state : {};
        var caseId = helper.getCaseIdFromContext(state);

        var vfUrl = "/apex/CCMIC_AE_CreateForm";
        var params = [];

        Object.keys(state).forEach(function(key) {
            if (state[key]) {
                params.push(encodeURIComponent(key) + "=" + encodeURIComponent(state[key]));
            }
        });

        if (caseId && !state.caseId) {
            params.push("caseId=" + encodeURIComponent(caseId));
        }

        if (params.length > 0) {
            vfUrl += "?" + params.join("&");
        }

        component.set("v.vfUrl", vfUrl);
    }
})
3. Aura Helper

Open AE_CreateFormLauncherHelper.js and use:

({
    getCaseIdFromContext : function(state) {
        if (state.caseId) {
            return state.caseId;
        }

        if (state.inContextOfRef) {
            var context = state.inContextOfRef;

            if (context.startsWith("1.")) {
                context = context.substring(2);
            }

            context = context.replace(/-/g, "+").replace(/_/g, "/");

            while (context.length % 4) {
                context += "=";
            }

            try {
                var decodedContext = JSON.parse(window.atob(context));
                return decodedContext.attributes.recordId;
            } catch (e) {
                console.log("Context decode error", e);
            }
        }

        return null;
    },

    registerTabTitleListener : function(component) {
        window.addEventListener("message", $A.getCallback(function(event) {
            if (!event.data || event.data.type !== "AE_SET_TAB_TITLE") {
                return;
            }

            var sourceId = event.data.sourceId;

            if (!sourceId) {
                return;
            }

            var workspaceAPI = component.find("workspace");

            workspaceAPI.isConsoleNavigation().then(function(isConsole) {
                if (isConsole) {
                    workspaceAPI.getFocusedTabInfo().then(function(tabInfo) {
                        workspaceAPI.setTabLabel({
                            tabId: tabInfo.tabId,
                            label: sourceId
                        });
                    });
                }
            });
        }), false);
    }
})
4. Add To VF Page

<script src="/support/console/60.0/integration.js" type="text/javascript"></script>

<!-- This logic goes at the VERY BOTTOM of your page -->
<script type="text/javascript">
    (function() {
        var iterations = 0;
        var maxIterations = 40; // This will try for 10 seconds (40 * 250ms)
        var sourceIdValue = "{!JSENCODE(sourceId)}";

        function ultimateTitleOverride() {
            // If the controller didn't provide a value, we can't set it.
            if (!sourceIdValue || sourceIdValue.trim() === "") {
                return;
            }

            if (typeof sforce !== "undefined" && sforce.console && sforce.console.isInConsole()) {
                sforce.console.getEnclosingTabId(function(result) {
                    if (result.id) {
                        // FORCE 1: Set the Title
                        sforce.console.setTabTitle(sourceIdValue, result.id);

                        // FORCE 2: Set the Icon (Standard Case Icon)
                        // This refresh often "un-sticks" the button name in Lightning
                        sforce.console.setTabIcon("standard:case", result.id);

                        console.log("Lightning Tab Update: Attempt " + iterations + " for " + sourceIdValue);
                    }
                });
            }

            // Also update browser title for non-console users
            document.title = sourceIdValue;

            iterations++;
            if (iterations < maxIterations) {
                // Try again in 250ms
                setTimeout(ultimateTitleOverride, 250);
            }
        }

        // Start the override sequence as soon as the page loads
        window.addEventListener("load", ultimateTitleOverride);
    })();
</script>
1. The Iframe Limitation (Visualforce in Lightning)
  Document: Lightning Experience Limitations - Visualforce (https://help.salesforce.com/s/articleView?id=sf.lex_al_visualforce_limitations.htm&type=5)
  > Key Point for Client: "Visualforce pages in Lightning Experience are wrapped in an iframe." 
  >
  > Why it matters: Because the page is inside an iframe, it cannot "reach out" to the main Salesforce tab to change its title like it could in Classic. This is a security and architectural standard in Lightning.

  2. Tab Label vs. Page Title
  Document: Developer Guide - Set Tab Titles in Lightning Experience (https://help.salesforce.com/s/articleView?id=000384832&type=1)
  > Key Point for Client: Standard browser attributes like <title> or <apex:page title="..."> do not work for console tabs in Lightning. 
  >
  > Why it matters: In Classic, these standard HTML tags were enough. In Lightning, Salesforce ignores them and defaults to the Action Label (the button name). The only way to change it is through complex JavaScript workarounds.

  3. Recommendation for Full Control (Workspace API)
