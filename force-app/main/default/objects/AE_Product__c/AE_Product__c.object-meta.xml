({
    doInit : function(component, event, helper) {
        var pageRef = component.get("v.pageReference");
        var caseId;

        if (pageRef && pageRef.state && pageRef.state.inContextOfRef) {
            var context = pageRef.state.inContextOfRef;

            if (context.startsWith("1.")) {
                context = context.substring(2);
            }

            context = context.replace(/-/g, "+").replace(/_/g, "/");

            var decodedContext = JSON.parse(window.atob(context));
            caseId = decodedContext.attributes.recordId;
        }

        if (!caseId) {
            console.log("Case Id not found from inContextOfRef");
            window.location.href = "/apex/CCMIC_AE_CreateForm";
            return;
        }

        var action = component.get("c.getSourceId");
        action.setParams({
            caseId: caseId
        });

        action.setCallback(this, function(response) {
            var sourceId = "New PAE";

            if (response.getState() === "SUCCESS" && response.getReturnValue()) {
                sourceId = response.getReturnValue();
            }

            var vfUrl = "/apex/CCMIC_AE_CreateForm?caseId=" + caseId;
            var workspaceAPI = component.find("workspace");

            workspaceAPI.isConsoleNavigation().then(function(isConsole) {
                if (isConsole) {
                    workspaceAPI.openTab({
                        url: vfUrl,
                        focus: true
                    }).then(function(tabId) {
                        window.setTimeout(function() {
                            workspaceAPI.setTabLabel({
                                tabId: tabId,
                                label: sourceId
                            });
                        }, 1000);
                    });
                } else {
                    window.location.href = vfUrl;
                }
            }).catch(function(error) {
                window.location.href = vfUrl;
            });
        });

        $A.enqueueAction(action);
    }
})
