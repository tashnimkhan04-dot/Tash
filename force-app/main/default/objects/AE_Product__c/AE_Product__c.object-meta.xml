public with sharing class AE_CreateFormLauncherController {

    @AuraEnabled(cacheable=true)
    public static String getSourceId(Id caseId) {
        List<New_Potential_Adverse_Event__c> paeList = [
            SELECT Id, Source_Id__c
            FROM New_Potential_Adverse_Event__c
            WHERE Case_PAE__c = :caseId
            ORDER BY CreatedDate DESC
            LIMIT 1
        ];

        if (!paeList.isEmpty() && String.isNotBlank(paeList[0].Source_Id__c)) {
            return paeList[0].Source_Id__c;
        }

        return 'New PAE';
    }
}
