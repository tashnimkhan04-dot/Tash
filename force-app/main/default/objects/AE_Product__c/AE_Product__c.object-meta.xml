<script>
window.addEventListener('load', function() {
    // Read potentialAE param from URL
    var urlParams = new URLSearchParams(window.location.search);
    var potentialAE = urlParams.get('potentialAE');
    if (potentialAE) {
        // Find the Potential AE picklist and set its value
        var selects = document.querySelectorAll("select");
        for (var i = 0; i < selects.length; i++) {
            var opts = selects[i].options;
            for (var j = 0; j < opts.length; j++) {
                if (opts[j].value === potentialAE) {
                    selects[i].value = potentialAE;
                    // Trigger change event
                    var event = new Event('change');
                    selects[i].dispatchEvent(event);
                    break;
                }
            }
        }
    }
});
</script>
